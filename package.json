{
  "name": "afrotech_suite",
  "private": true,
  "version": "0.0.1-beta.1",
  "type": "module",
  "main": "src/electron/main.cjs",
  "author": "AfroditeSoft",
  "description": "AfroTech Suite launcher and technical workspace dashboard",
  "scripts": {
    "dev": "vite --open",
    "serve": "vite --host 127.0.0.1",
    "build": "vite build --configLoader native",
    "build:portable": "vite build --configLoader native && electron-builder --win portable",
    "lint": "eslint .",
    "test": "vitest run --configLoader native --pool threads --no-file-parallelism",
    "test:watch": "vitest --configLoader native --pool threads --no-file-parallelism",
    "test:coverage": "vitest run --configLoader native --pool threads --no-file-parallelism --coverage",
    "preview": "vite preview",
    "electron": "electron .",
    "desktop": "electron .",
    "electron:build": "vite build && electron-builder",
    "schema:check": "node scripts/schema-sync.cjs check"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "build": {
    "appId": "com.afroditesoft.afrotech-suite",
    "productName": "AfroTech Suite",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/electron/**/*"
    ],
    "win": {
      "target": "portable"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  }
}
